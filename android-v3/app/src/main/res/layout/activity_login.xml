<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <!-- Scrollable main content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Spacer for status bar + menu -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            <!-- Logo Container — rounded-rect card with shadow -->
            <androidx.cardview.widget.CardView
                android:layout_width="140dp"
                android:layout_height="140dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_gravity="center_horizontal">

                <ImageView
                    android:id="@+id/logoImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/app_logo"
                    android:scaleType="centerInside"
                    android:padding="24dp" />
            </androidx.cardview.widget.CardView>

            <!-- Brand Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Umingle"
                android:textSize="38sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-black"
                android:layout_marginTop="24dp"
                android:letterSpacing="-0.02" />

            <!-- Tagline — orange -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Talk to simple strangers!"
                android:textSize="16sp"
                android:textColor="@color/brand_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvAppSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The classic video chat experience."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="10dp" />

            <!-- Users Live Badge -->
            <LinearLayout
                android:id="@+id/layoutLiveUsersBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_live_badge"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:layout_marginTop="24dp">

                <!-- Green dot -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_green_dot" />

                <TextView
                    android:id="@+id/tvLiveUsersCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="32,451 Users Live"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Spacer to push bottom card down -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="40dp" />

            <!-- Bottom Sheet Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/bottomSheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="16dp"
                app:cardBackgroundColor="@color/v2_sheet_bg"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="28dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="36dp"
                    android:gravity="center_horizontal">

                    <!-- Heading -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start chatting now"
                        android:textSize="22sp"
                        android:textColor="@color/v2_sheet_text"
                        android:fontFamily="sans-serif-bold" />

                    <!-- Google Sign-In Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoogleSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Continue with Google"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="28dp"
                        android:backgroundTint="#FFFFFF"
                        app:icon="@drawable/ic_google_logo"
                        app:iconTint="@null"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        android:layout_marginTop="24dp"
                        app:strokeColor="#E8E8E8"
                        app:strokeWidth="1dp"
                        app:elevation="2dp" />

                    <!-- Guest Login Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuestLogin"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Enter as Guest"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="28dp"
                        android:backgroundTint="@color/brand_primary"
                        android:layout_marginTop="12dp"
                        app:elevation="2dp" />

                    <!-- Footer Text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anonymous. Instant. Safe."
                        android:textColor="@color/v2_sheet_text_dim"
                        android:textSize="12sp"
                        android:layout_marginTop="20dp"
                        android:alpha="0.7" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Sidebar Button — hamburger icon, top-left -->
    <ImageButton
        android:id="@+id/btnSidebar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="44dp"
        android:src="@drawable/ic_menu_modern"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/text_primary"
        android:scaleType="centerInside"
        android:padding="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Menu" />

    <!-- Sidebar Overlay -->
    <View
        android:id="@+id/sidebarOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- Sidebar — left-aligned drawer -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/v2_sheet_bg"
        android:visibility="gone"
        android:elevation="32dp"
        app:layout_constraintWidth_percent="0.82"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Drawer Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="56dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="24dp"
            android:background="@drawable/bg_login_gradient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/app_logo"
                    android:scaleType="fitCenter"
                    android:background="@drawable/bg_logo_circle"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Umingle"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginStart="14dp" />

                <ImageButton
                    android:id="@+id/btnSidebarClose"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/text_primary" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect with people worldwide"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="10dp"
                android:alpha="0.8" />
        </LinearLayout>

        <!-- Nav Items -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="12dp">

                <!-- About -->
                <LinearLayout
                    android:id="@+id/sidebarItemSafety"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/feature_icon_live" app:tint="@color/brand_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="About App" android:textColor="@color/v2_sheet_text" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Blog -->
                <LinearLayout
                    android:id="@+id/sidebarItemBlog"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/feature_icon_global" app:tint="@color/brand_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Blog" android:textColor="@color/v2_sheet_text" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Privacy Policy -->
                <LinearLayout
                    android:id="@+id/sidebarItemPrivacy"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/feature_icon_secure" app:tint="@color/brand_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Privacy Policy" android:textColor="@color/v2_sheet_text" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Terms -->
                <LinearLayout
                    android:id="@+id/sidebarItemTerms"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/feature_icon_anonymous" app:tint="@color/brand_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terms of Service" android:textColor="@color/v2_sheet_text" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Community -->
                <LinearLayout
                    android:id="@+id/sidebarItemCommunity"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/feature_icon_video" app:tint="@color/brand_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Community Rules" android:textColor="@color/v2_sheet_text" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Cookies -->
                <LinearLayout
                    android:id="@+id/sidebarItemCookies"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/feature_icon_free" app:tint="@color/brand_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cookie Policy" android:textColor="@color/v2_sheet_text" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="16dp" />
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#10000000" android:layout_marginVertical="8dp" android:layout_marginHorizontal="24dp" />

                <!-- How It Works -->
                <LinearLayout
                    android:id="@+id/sidebarItemHowItWorks"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:background="?attr/selectableItemBackground">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/feature_icon_video" app:tint="#9CA3AF" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="How It Works" android:textColor="#6B7280" android:textSize="15sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="16dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Drawer Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingVertical="16dp" />

    </LinearLayout>

    <!-- Document Modal -->
    <androidx.cardview.widget.CardView
        android:id="@+id/documentModal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:cardCornerRadius="32dp"
        app:cardElevation="32dp"
        app:cardBackgroundColor="@color/v2_sheet_bg"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="-30dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">
                <TextView
                    android:id="@+id/documentTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/v2_sheet_text"
                    android:text="Document"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnDocumentClose"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
                <ImageButton
                    android:id="@+id/btnDocumentClose"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/v2_sheet_text"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#10000000" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">
                <TextView
                    android:id="@+id/documentContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/v2_sheet_text_dim"
                    android:lineSpacingMultiplier="1.6"
                    android:text="Loading..." />
            </androidx.core.widget.NestedScrollView>

            <ProgressBar
                android:id="@+id/documentProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/brand_primary" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
