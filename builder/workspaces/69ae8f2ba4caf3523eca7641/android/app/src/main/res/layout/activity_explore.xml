<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/v2_sheet_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/v2_sheet_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="How It Works"
            android:textSize="22sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="@color/v2_sheet_text"
            android:gravity="center" />

        <View android:layout_width="44dp" android:layout_height="44dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#08000000" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Step 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F0F4FF"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="1"
                        android:textSize="22sp"
                        android:textColor="@color/brand_primary"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_logo_circle" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create Your Profile"
                            android:textSize="16sp"
                            android:textColor="@color/v2_sheet_text"
                            android:fontFamily="sans-serif-bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign in with Google or continue as a guest. Your identity stays protected."
                            android:textSize="13sp"
                            android:textColor="@color/v2_sheet_text_dim"
                            android:layout_marginTop="4dp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Step 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#F0FFF4"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="2"
                        android:textSize="22sp"
                        android:textColor="#22C55E"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_logo_circle" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get Matched Instantly"
                            android:textSize="16sp"
                            android:textColor="@color/v2_sheet_text"
                            android:fontFamily="sans-serif-bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Our algorithm pairs you with people online right now. No waiting, no swiping."
                            android:textSize="13sp"
                            android:textColor="@color/v2_sheet_text_dim"
                            android:layout_marginTop="4dp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Step 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF7ED"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="3"
                        android:textSize="22sp"
                        android:textColor="#F97316"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_logo_circle" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start Video Chat"
                            android:textSize="16sp"
                            android:textColor="@color/v2_sheet_text"
                            android:fontFamily="sans-serif-bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Face-to-face conversations with real people. Skip anytime, next match is one tap away."
                            android:textSize="13sp"
                            android:textColor="@color/v2_sheet_text_dim"
                            android:layout_marginTop="4dp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Step 4 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FDF2F8"
                android:layout_marginBottom="28dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="4"
                        android:textSize="22sp"
                        android:textColor="#EC4899"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_logo_circle" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Stay Safe"
                            android:textSize="16sp"
                            android:textColor="@color/v2_sheet_text"
                            android:fontFamily="sans-serif-bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Report or block anyone instantly. Our moderation team works 24/7 to keep you safe."
                            android:textSize="13sp"
                            android:textColor="@color/v2_sheet_text_dim"
                            android:layout_marginTop="4dp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Features section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Key Features"
                android:textSize="20sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/v2_sheet_text"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#F9FAFB"
                    android:layout_marginEnd="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/feature_icon_anonymous" app:tint="@color/brand_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Anonymous" android:textSize="12sp" android:textColor="@color/v2_sheet_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#F9FAFB"
                    android:layout_marginHorizontal="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/feature_icon_global" app:tint="@color/brand_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Worldwide" android:textSize="12sp" android:textColor="@color/v2_sheet_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#F9FAFB"
                    android:layout_marginStart="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/feature_icon_secure" app:tint="@color/brand_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Secure" android:textSize="12sp" android:textColor="@color/v2_sheet_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="40dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#F9FAFB"
                    android:layout_marginEnd="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/feature_icon_video" app:tint="@color/brand_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HD Video" android:textSize="12sp" android:textColor="@color/v2_sheet_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#F9FAFB"
                    android:layout_marginHorizontal="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/feature_icon_free" app:tint="@color/brand_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100% Free" android:textSize="12sp" android:textColor="@color/v2_sheet_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#F9FAFB"
                    android:layout_marginStart="6dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="20dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/feature_icon_live" app:tint="@color/brand_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Live Match" android:textSize="12sp" android:textColor="@color/v2_sheet_text" android:fontFamily="sans-serif-medium" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <View android:id="@+id/gen_view_ba4e49" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:alpha="0" android:tag="4dc823eb" />
    <View android:id="@+id/gen_view_c554ce" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:alpha="0" android:tag="ac332735" />
    <View android:id="@+id/gen_view_3b379c" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:alpha="0" android:tag="07322e0a" />
</LinearLayout>
