<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- Hero Section -->
            <LinearLayout
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:layout_marginTop="80dp"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="20dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <ImageView
                        android:id="@+id/logoImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:src="@drawable/app_logo"
                        android:scaleType="fitCenter"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Docker Video Chat"
                    android:textSize="52sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginTop="24dp"
                    android:letterSpacing="-0.03"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Docker chat hg"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp"
                    android:alpha="0.9"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="4dp"
                    android:background="@color/brand_primary"
                    android:layout_marginTop="24dp"
                    app:cornerRadius="2dp"/>
            </LinearLayout>

            <!-- Main Action Card (Glassmorphism) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bottomCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="60dp"
                android:padding="32dp"
                android:background="@drawable/bg_glass_card"
                app:layout_constraintTop_toBottomOf="@id/heroSection">

                <TextView
                    android:id="@+id/loginTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to Start?"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogleSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Sign in with Google"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="20dp"
                    android:backgroundTint="#FFFFFF"
                    app:icon="@drawable/ic_google_logo"
                    app:iconTint="@null"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    android:layout_marginTop="32dp"
                    app:layout_constraintTop_toBottomOf="@id/loginTitle"
                    app:elevation="8dp"/>

                <LinearLayout
                    android:id="@+id/dividerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/btnGoogleSignIn">
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#40FFFFFF" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="or stay anonymous" android:textSize="12sp" android:textColor="@color/text_secondary" android:layout_marginHorizontal="16dp" android:alpha="0.7"/>
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#40FFFFFF" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuestLogin"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Enter as Guest"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="20dp"
                    android:backgroundTint="@color/brand_primary"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/dividerLayout"
                    app:elevation="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By continuing, you agree to our Terms and Privacy."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="24dp"
                    android:alpha="0.6"
                    android:gravity="center"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnGuestLogin"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Secondary Links -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/bottomCard">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDiscover"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explore Docker Video Chat ✨"
                    android:textColor="@color/brand_primary"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    app:rippleColor="#20FFFFFF"/>

                <TextView
                    android:id="@+id/statsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 42,890 users active now"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:alpha="0.8"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sidebar Button (Modern) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnSidebar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:srcCompat="@drawable/ic_menu_modern"
        app:backgroundTint="#26FFFFFF"
        app:tint="@color/text_primary"
        app:elevation="0dp"
        app:borderWidth="1dp"
        app:strokeColor="#40FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Menu"/>

    <!-- Sidebar Overlay & Layout (Re-styled) -->
    <View
        android:id="@+id/sidebarOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3050510"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sidebar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:background="@color/brand_background_end"
        android:visibility="gone"
        android:elevation="24dp"
        app:layout_constraintWidth_percent="0.8"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/sidebarHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="60dp"
            android:paddingBottom="32dp"
            android:paddingHorizontal="32dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnSidebarClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_primary"
                android:layout_gravity="end"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textSize="36sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/sidebarHeader"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <TextView android:id="@+id/sidebarItemSafety" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔥 Docker Video Chat Trends" android:textColor="@color/brand_primary" android:textStyle="bold" android:padding="24dp" android:textSize="18sp" android:background="?attr/selectableItemBackground"/>
                <TextView android:id="@+id/sidebarItemPrivacy" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Privacy Policy" android:textColor="@color/text_primary" android:padding="24dp" android:textSize="18sp" android:background="?attr/selectableItemBackground" android:alpha="0.9"/>
                <TextView android:id="@+id/sidebarItemTerms" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Terms of Service" android:textColor="@color/text_primary" android:padding="24dp" android:textSize="18sp" android:background="?attr/selectableItemBackground" android:alpha="0.9"/>
                <TextView android:id="@+id/sidebarItemCommunity" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Community Rules" android:textColor="@color/text_primary" android:padding="24dp" android:textSize="18sp" android:background="?attr/selectableItemBackground" android:alpha="0.9"/>
                <TextView android:id="@+id/sidebarItemCookies" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Cookie Policy" android:textColor="@color/text_primary" android:padding="24dp" android:textSize="18sp" android:background="?attr/selectableItemBackground" android:alpha="0.9"/>

            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Document Modal (Matching theme) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/documentModal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:cardCornerRadius="32dp"
        app:cardElevation="32dp"
        app:cardBackgroundColor="@color/brand_background_end"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="-30dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">
                <TextView
                    android:id="@+id/documentTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/text_primary"
                    android:text="Document"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btnDocumentClose"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
                <ImageButton
                    android:id="@+id/btnDocumentClose"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/text_primary"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#20FFFFFF"/>

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">
                <TextView
                    android:id="@+id/documentContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.6"
                    android:text="Loading..."/>
            </androidx.core.widget.NestedScrollView>

            <ProgressBar
                android:id="@+id/documentProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/brand_primary"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <View android:id="@+id/gen_view_d4440f" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:alpha="0" android:tag="2e596636" />
</androidx.constraintlayout.widget.ConstraintLayout>
