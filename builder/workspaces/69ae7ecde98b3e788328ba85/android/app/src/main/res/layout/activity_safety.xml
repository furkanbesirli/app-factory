<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/v2_sheet_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <ImageButton
            android:id="@+id/btnPulseBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/v2_sheet_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="About"
            android:textSize="22sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="@color/v2_sheet_text"
            android:gravity="center" />

        <View android:layout_width="44dp" android:layout_height="44dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#08000000" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- App Logo & Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="32dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/app_logo"
                    android:scaleType="fitCenter"
                    android:background="@drawable/bg_logo_circle"
                    android:padding="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="logo2"
                    android:textSize="28sp"
                    android:textColor="@color/v2_sheet_text"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v1.0.0"
                    android:textSize="13sp"
                    android:textColor="@color/v2_sheet_text_dim"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Mission -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#F9FAFB"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Our Mission"
                        android:textSize="17sp"
                        android:textColor="@color/v2_sheet_text"
                        android:fontFamily="sans-serif-bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="We believe in genuine human connections. Our platform brings people together through live video conversations — spontaneous, authentic, and fun."
                        android:textSize="14sp"
                        android:textColor="@color/v2_sheet_text_dim"
                        android:layout_marginTop="8dp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Safety -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#F0FFF4"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/feature_icon_secure" app:tint="#22C55E" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Safety Matters"
                            android:textSize="17sp"
                            android:textColor="@color/v2_sheet_text"
                            android:fontFamily="sans-serif-bold"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Report or block anyone with one tap\n• 24/7 content moderation team\n• No personal data shared with strangers\n• End-to-end encrypted connections"
                        android:textSize="14sp"
                        android:textColor="@color/v2_sheet_text_dim"
                        android:layout_marginTop="10dp"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Contact -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="#F9FAFB"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Us"
                        android:textSize="17sp"
                        android:textColor="@color/v2_sheet_text"
                        android:fontFamily="sans-serif-bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Have questions or feedback? We'd love to hear from you."
                        android:textSize="14sp"
                        android:textColor="@color/v2_sheet_text_dim"
                        android:layout_marginTop="8dp"
                        android:lineSpacingMultiplier="1.4" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPulseAction"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="Send Feedback"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/brand_primary"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Legal footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Made with care. All rights reserved."
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <View android:id="@+id/gen_view_3ff1d7" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:alpha="0" android:tag="546e6c85" />
</LinearLayout>
